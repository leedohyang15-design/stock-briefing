# ── LLM 요약 (Gemini 무료 또는 Claude) ────────────────
# 둘 다 없으면 LLM 요약 없이 원본 데이터로 폴백 발송됩니다.
# 둘 다 있으면 Gemini(무료)를 우선 사용합니다.

# [추천] Google Gemini — 무료, 신용카드 불필요
# 발급: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# [선택] Claude — 크레딧(유료) 필요
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# ── 이메일 발송 (SMTP) ────────────────────────────────
# Gmail 기준. 반드시 "앱 비밀번호"를 사용하세요 (일반 비밀번호 아님).
# 발급: Google 계정 > 보안 > 2단계 인증 > 앱 비밀번호
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASSWORD=your_16_char_app_password

# 브리핑 수신자 (쉼표로 여러 명 지정 가능: a@x.com,b@y.com)
MAIL_TO=your_gmail@gmail.com

# 발신자 표시 이름
MAIL_FROM_NAME=데일리 주식 브리핑

# ── 카카오톡 '나에게 보내기' (선택, 무료) ──────────────
# 이메일과 병행해 폰으로 핵심 요약 알림을 받고 싶을 때만 설정하세요.
# 발급 방법: python scripts/kakao_auth.py  (한 번만 실행 → refresh_token 획득)
# 자세한 안내는 README '카카오톡 알림' 섹션 참고.
KAKAO_REST_KEY=
KAKAO_REFRESH_TOKEN=
# Redirect URI — 카카오 개발자 콘솔에 등록한 값과 반드시 동일해야 함
KAKAO_REDIRECT_URI=https://localhost

# ※ 관심 테마·종목은 config/watchlist.yaml 에서 직접 수정하세요.
